                                tr
                                    td Number of Bifurcations
                                    td(id="n_bifs")
                                tr
                                    td Number of Branches
                                    td(id="n_branch")
                                tr
                                    td Overall Width
                                    td(id="width")
                                tr
                                    td Overall Height
                                    td(id="height")
                                tr
                                    td Overall Depth
                                    td(id="depth")
                                tr
                                    td Average Diameter
                                    td(id="diameter")
                                tr
                                    td Total Length
                                    td(id="length")
                                tr
                                    td Total Surface
                                    td(id="surface")
                                tr
                                    td Total Volume
                                    td(id="volume")
                                tr
                                    td Max Euclidean Distance
                                    td(id="eucdistance")
                                tr
                                    td Max Path Distance
                                    td(id="pathdistance")
                                tr
                                    td Max Branch Order
                                    td(id="branch_order")
                                tr
                                    td Average Contraction
                                    td(id="contraction")
                                tr
                                    td Total Fragmentation
                                    td(id="fragmentation")
                                tr
                                    td Partition Asymmetry
                                    td(id="partition_asymmetry")
                                tr
                                    td Average Rall's Ratio
                                    td(id="pk_classic")
                                tr
                                    td Average Bifurcation Angle Local
                                    td(id="bif_ampl_local")
                                tr
                                    td Average Bifurcation Angle Remote
                                    td(id="bif_ampl_remote")
                                tr
                                    td Fractal Dimension
                                    td(id="fractal_dim")
                                
                                 
                                
                                
                                
                                
                    
            



block footer

    include mixins/footer.pug
    +footer({
        footerBg: 'bg-light',
        footerStyle: 'footer-light'
    })  
    script(src='js/base.js')
    script(src='js/neuroninfo.js')
    script updatevals(new URLSearchParams(window.location.search));
    script. 
        function winpop(path,name) {
            var imgHeight;
            var imgWidth;
            var myImage = new Image();
            myImage.src = path
            myImage.onload = function() {
                imgHeight=myImage.height;
                imgWidth=myImage.width;
                imgHeight=imgHeight+20;
                imgWidth=imgWidth+20;
                
                
                var newWindow=window.open(path,'linkname','height='+imgHeight+',width='+imgWidth+',scrollbars=no');        
                newWindow.document.write("<head><meta name=\"viewport\" content=\"width=device-width, minimum-scale=0.1\"><title>"+name+"</title></head><body style=\"margin: 0px;background: black; \"><div align=\"center\" style=\"margin-top: 10px; margin-bottom: 10px;\"> <img src="+path+"></div></body>");
            };
        }
